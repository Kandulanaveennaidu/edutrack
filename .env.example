# ═══════════════════════════════════════════════════════════════
#  CampusIQ Environment Variables
#  Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ──── REQUIRED ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/edutrack?retryWrites=true&w=majority
NEXTAUTH_SECRET=your-super-secret-key-change-this-to-random-string
NEXTAUTH_URL=https://your-app-name.onrender.com
NODE_ENV=production

# ──── Optional: Email / SMTP (for password reset, verification) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL="CampusIQ" <noreply@campusiq.com>

# ──── Optional: Cloudinary (Image/File Uploads) ────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ──── Optional: Twilio SMS & WhatsApp ────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+1xxxxxxxxxx

# ──── Optional: Google Gemini AI (AI Chatbot) ────
GEMINI_API_KEY=your-gemini-api-key

# ──── Optional: Razorpay Payments ────
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ──── Optional: Authorize.net Payments ────
AUTHORIZE_NET_API_LOGIN_ID=your-login-id
AUTHORIZE_NET_TRANSACTION_KEY=your-transaction-key
AUTHORIZE_NET_SANDBOX=true

# ──── Optional: UPI Payments ────
UPI_MERCHANT_VPA=school@upi
SCHOOL_NAME=CampusIQ School

# ──── Optional: Push Notifications (VAPID) ────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ──── Optional: Cron Jobs ────
CRON_SECRET=your-cron-secret

# ──── Optional: Logging ────
LOG_LEVEL=info